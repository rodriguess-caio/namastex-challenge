# GitHub personal access token with repo and admin:repo_hook scopes
GITHUB_TOKEN=ghp_your_token_here

# GitHub repository owner and name for webhook registration
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_repository_name

# Secret used to validate GitHub webhook HMAC-SHA256 signatures
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# WhatsApp phone number to receive notifications (E.164 format, e.g. 5511999999999)
NOTIFY_PHONE=5511999999999

# ngrok fixed domain for stable webhook URL across restarts (e.g. your-subdomain.ngrok-free.app)
NGROK_DOMAIN=your-subdomain.ngrok-free.app

# ngrok authentication token (from https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Omni API base URL (e.g. http://localhost:8882)
OMNI_API_URL=http://localhost:8882

# Omni API key for authenticating requests
OMNI_API_KEY=your_omni_api_key_here
