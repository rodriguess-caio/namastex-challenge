{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@github/mcp-server"],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(omni say *)",
      "Bash(omni send *)",
      "Bash(omni done)",
      "Bash(omni react *)",
      "Bash(omni speak *)",
      "Bash(omni imagine *)",
      "Bash(sqlite3 data/db.sqlite *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv /*)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(chmod 777 *)",
      "Bash(sudo *)"
    ]
  }
}
